/**
 * Particle System & Dynamic Lighting
 * Aggiunge effetti visivi avanzati: particelle, illuminazione, screen shake
 */

var ParticleSystem = {
  particles: [],
  maxParticles: 200,
  
  /**
   * Crea una particella
   */
  create: function(x, y, type, options) {
    if (this.particles.length >= this.maxParticles) {
      this.particles.shift();
    }
    
    var particle = {
      x: x,
      y: y,
      type: type,
      life: options.life || 60,
      maxLife: options.life || 60,
      vx: options.vx || (Math.random() - 0.5) * 0.5,
      vy: options.vy || (Math.random() - 0.5) * 0.5,
      size: options.size || 2,
      color: options.color || '#FFFFFF',
      alpha: options.alpha || 1,
      gravity: options.gravity || 0,
      friction: options.friction || 0.98
    };
    
    this.particles.push(particle);
    return particle;
  },
  
  /**
   * Crea lucciole (fireflies) per il campo
   */
  createFireflies: function(x, y) {
    for (var i = 0; i < 15; i++) {
      this.create(
        x + Math.random() * 300,
        y + Math.random() * 200,
        'firefly',
        {
          life: 120 + Math.random() * 60,
          vx: (Math.random() - 0.5) * 0.3,
          vy: (Math.random() - 0.5) * 0.3,
          size: 1 + Math.random() * 2,
          color: '#FFFF88',
          alpha: 0.6 + Math.random() * 0.4,
          gravity: -0.01
        }
      );
    }
  },
  
  /**
   * Crea polvere per interni
   */
  createDust: function(x, y) {
    for (var i = 0; i < 10; i++) {
      this.create(
        x + Math.random() * 300,
        y + Math.random() * 200,
        'dust',
        {
          life: 180 + Math.random() * 120,
          vx: (Math.random() - 0.5) * 0.2,
          vy: -0.1 - Math.random() * 0.1,
          size: 1,
          color: '#CCCCCC',
          alpha: 0.3 + Math.random() * 0.2,
          gravity: 0.005
        }
      );
    }
  },
  
  /**
   * Crea scintille quando si raccoglie un indizio
   */
  createSparkles: function(x, y) {
    for (var i = 0; i < 20; i++) {
      var angle = (Math.PI * 2 / 20) * i;
      var speed = 1 + Math.random() * 2;
      this.create(
        x, y,
        'sparkle',
        {
          life: 30 + Math.random() * 20,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          size: 2 + Math.random() * 2,
          color: '#FFD700',
          alpha: 1,
          gravity: 0.05,
          friction: 0.95
        }
      );
    }
  },
  
  /**
   * Aggiorna tutte le particelle
   */
  update: function() {
    for (var i = this.particles.length - 1; i >= 0; i--) {
      var p = this.particles[i];
      
      p.x += p.vx;
      p.y += p.vy;
      p.vy += p.gravity;
      p.vx *= p.friction;
      p.vy *= p.friction;
      p.life--;
      
      // Fade out
      p.alpha = (p.life / p.maxLife) * p.alpha;
      
      if (p.life <= 0) {
        this.particles.splice(i, 1);
      }
    }
  },
  
  /**
   * Disegna tutte le particelle
   */
  draw: function(ctx) {
    for (var i = 0; i < this.particles.length; i++) {
      var p = this.particles[i];
      
      ctx.save();
      ctx.globalAlpha = p.alpha;
      
      if (p.type === 'firefly') {
        // Lucciola: cerchio luminoso
        ctx.fillStyle = p.color;
        ctx.fillRect(Math.floor(p.x), Math.floor(p.y), p.size, p.size);
        
        // Alone
        ctx.globalAlpha = p.alpha * 0.3;
        ctx.fillRect(Math.floor(p.x) - 1, Math.floor(p.y) - 1, p.size + 2, p.size + 2);
      } else if (p.type === 'dust') {
        // Polvere: piccolo punto
        ctx.fillStyle = p.color;
        ctx.fillRect(Math.floor(p.x), Math.floor(p.y), 1, 1);
      } else if (p.type === 'sparkle') {
        // Scintilla: stella
        ctx.fillStyle = p.color;
        ctx.fillRect(Math.floor(p.x), Math.floor(p.y), p.size, p.size);
      }
      
      ctx.restore();
    }
  },
  
  /**
   * Pulisce tutte le particelle
   */
  clear: function() {
    this.particles = [];
  }
};

/**
 * Dynamic Lighting System
 * Aggiunge aloni luminosi dinamici
 */
var LightingSystem = {
  lights: [],
  
  /**
   * Aggiunge una luce
   */
  addLight: function(x, y, radius, color, intensity) {
    this.lights.push({
      x: x,
      y: y,
      radius: radius || 30,
      color: color || '#FFAA44',
      intensity: intensity || 0.3,
      flicker: Math.random() * 0.05
    });
  },
  
  /**
   * Aggiunge luci ambiente per un'area
   */
  setupAreaLights: function(areaId) {
    this.lights = [];
    
    switch (areaId) {
      case 'piazze':
        // Lampioni
        this.addLight(50, 100, 40, '#FFAA44', 0.2);
        this.addLight(200, 100, 40, '#FFAA44', 0.2);
        this.addLight(350, 100, 40, '#FFAA44', 0.2);
        // Finestre
        this.addLight(46, 52, 20, '#FFCC66', 0.15);
        this.addLight(76, 52, 20, '#FFCC66', 0.15);
        break;
        
      case 'chiesa':
        // Vetrate colorate
        this.addLight(185, 50, 30, '#FF4444', 0.2);
        this.addLight(203, 50, 30, '#4444FF', 0.2);
        // Lampada confessionale
        this.addLight(196, 104, 30, '#FFAA44', 0.25);
        break;
        
      case 'cimitero':
        // Mausoleo
        this.addLight(310, 100, 25, '#FFCC66', 0.15);
        break;
        
      case 'giardini':
        // Fontana piccola
        this.addLight(200, 164, 20, '#AABBDD', 0.2);
        // Farfalla
        var t = Date.now() * 0.001;
        var bx = 250 + Math.sin(t*1.2)*20;
        var by = 120 + Math.cos(t*1.8)*10;
        this.addLight(bx, by, 15, '#AA66CC', 0.3);
        break;
        
      case 'bar_exterior':
        // Insegna luminosa
        var signPulse = Math.sin(Date.now()*0.003)*0.3+0.7;
        this.addLight(190, 30, 25, '#CC0000', signPulse*0.3);
        // Finestre illuminate
        this.addLight(132, 52, 20, '#FFAA44', 0.2);
        this.addLight(232, 52, 20, '#FFAA44', 0.2);
        break;
        
      case 'residenziale':
        // Finestre case
        this.addLight(37, 52, 18, '#FFCC66', 0.15);
        this.addLight(67, 52, 18, '#FFCC66', 0.15);
        this.addLight(177, 47, 20, '#FFCC66', 0.15);
        this.addLight(212, 47, 20, '#FFCC66', 0.15);
        this.addLight(317, 57, 16, '#FFCC66', 0.15);
        break;
        
      case 'industriale':
        // Capannoni
        var flicker = Math.sin(Date.now()*0.005)*0.3+0.5;
        this.addLight(47, 47, 20, '#FFAA44', flicker*0.2);
        this.addLight(82, 47, 20, '#FFAA44', flicker*0.2);
        this.addLight(217, 57, 18, '#FFAA44', 0.15);
        // Ciminiera fumo (luci riflesse)
        this.addLight(350, 15, 30, '#FFFFFF', 0.1);
        break;
        
      case 'polizia':
        // Insegna
        this.addLight(200, 18, 35, '#CC0000', 0.25);
        // Finestre con sbarre
        this.addLight(132, 52, 20, '#AABBDD', 0.15);
        this.addLight(172, 52, 20, '#AABBDD', 0.15);
        this.addLight(222, 52, 20, '#AABBDD', 0.15);
        this.addLight(262, 52, 20, '#AABBDD', 0.15);
        // Lampeggianti auto
        var flash = Math.sin(Date.now()*0.006) > 0;
        if(flash) {
          this.addLight(295, 143, 12, '#FF0000', 0.3);
          this.addLight(315, 143, 12, '#0000FF', 0.2);
        } else {
          this.addLight(295, 143, 12, '#0000FF', 0.2);
          this.addLight(315, 143, 12, '#FF0000', 0.3);
        }
        break;
    }
  },
  
  /**
   * Aggiorna le luci (flicker)
   */
  update: function() {
    for (var i = 0; i < this.lights.length; i++) {
      var light = this.lights[i];
      light.intensity += (Math.random() - 0.5) * light.flicker;
      light.intensity = Math.max(0.1, Math.min(0.4, light.intensity));
    }
  },
  
  /**
   * Disegna tutte le luci
   */
  draw: function(ctx, playerX, playerY) {
    // Luci ambiente (nessuna luce sul player)
    for (var i = 0; i < this.lights.length; i++) {
      var light = this.lights[i];
      this.drawLight(ctx, light.x, light.y, light.radius, light.color, light.intensity);
    }
  },
  
  /**
   * Disegna una singola luce con gradiente radiale
   */
  drawLight: function(ctx, x, y, radius, color, intensity) {
    ctx.save();
    ctx.globalCompositeOperation = 'screen';
    
    var gradient = ctx.createRadialGradient(x, y, 0, x, y, radius);
    gradient.addColorStop(0, color.replace(')', ',' + intensity + ')').replace('rgb', 'rgba'));
    gradient.addColorStop(1, color.replace(')', ',0)').replace('rgb', 'rgba'));
    
    ctx.fillStyle = gradient;
    ctx.fillRect(x - radius, y - radius, radius * 2, radius * 2);
    
    ctx.restore();
  }
};

/**
 * Screen Shake Effect
 */
var ScreenShake = {
  active: false,
  intensity: 0,
  duration: 0,
  timer: 0,
  offsetX: 0,
  offsetY: 0,
  
  /**
   * Attiva lo screen shake
   */
  shake: function(intensity, duration) {
    this.active = true;
    this.intensity = intensity || 3;
    this.duration = duration || 10;
    this.timer = 0;
  },
  
  /**
   * Aggiorna lo screen shake
   */
  update: function() {
    if (!this.active) return;
    
    this.timer++;
    if (this.timer >= this.duration) {
      this.active = false;
      this.offsetX = 0;
      this.offsetY = 0;
      return;
    }
    
    var progress = this.timer / this.duration;
    var currentIntensity = this.intensity * (1 - progress);
    
    this.offsetX = (Math.random() - 0.5) * currentIntensity;
    this.offsetY = (Math.random() - 0.5) * currentIntensity;
  },
  
  /**
   * Applica lo shake al context
   */
  apply: function(ctx) {
    if (this.active) {
      ctx.translate(this.offsetX, this.offsetY);
    }
  },
  
  /**
   * Reset dello shake
   */
  reset: function() {
    this.active = false;
    this.offsetX = 0;
    this.offsetY = 0;
  }
};

/**
 * Vignette Effect
 * Aggiunge una vignettatura ai bordi del canvas
 */
var Vignette = {
  intensity: 0.4,
  color: '#000000',
  
  /**
   * Disegna la vignettatura
   */
  draw: function(ctx, width, height) {
    ctx.save();
    ctx.globalCompositeOperation = 'multiply';
    
    var gradient = ctx.createRadialGradient(
      width / 2, height / 2, height * 0.3,
      width / 2, height / 2, width * 0.7
    );
    
    gradient.addColorStop(0, 'rgba(0,0,0,0)');
    gradient.addColorStop(1, this.color);
    
    ctx.fillStyle = gradient;
    ctx.globalAlpha = this.intensity;
    ctx.fillRect(0, 0, width, height);
    
    ctx.restore();
  }
};

/**
 * Weather System
 * Sistema meteo con pioggia, fulmini, neve
 */
var WeatherSystem = {
  active: false,
  type: 'none', // 'rain', 'snow', 'storm'
  intensity: 0.5,
  particles: [],
  lightningTimer: 0,
  lightningActive: false,
  
  /**
   * Attiva un tipo di meteo
   */
  setWeather: function(type, intensity) {
    this.type = type;
    this.intensity = intensity || 0.5;
    this.active = type !== 'none';
    this.particles = [];
    
    // Inizializza particelle
    if (this.active) {
      var count = type === 'rain' ? 100 * intensity : (type === 'snow' ? 50 * intensity : 150);
      for (var i = 0; i < count; i++) {
        this.particles.push(this.createParticle());
      }
    }
  },
  
  /**
   * Crea una particella meteo
   */
  createParticle: function() {
    return {
      x: Math.random() * CANVAS_W,
      y: Math.random() * CANVAS_H,
      vx: this.type === 'snow' ? (Math.random() - 0.5) * 0.5 : -0.5,
      vy: this.type === 'rain' ? 8 + Math.random() * 4 : (this.type === 'snow' ? 0.5 + Math.random() : 10),
      size: this.type === 'rain' ? 1 : (this.type === 'snow' ? 2 : 1),
      alpha: 0.3 + Math.random() * 0.4
    };
  },
  
  /**
   * Aggiorna il meteo
   */
  update: function() {
    if (!this.active) return;
    
    // Fulmini durante i temporali
    if (this.type === 'storm') {
      this.lightningTimer--;
      if (this.lightningTimer <= 0) {
        this.lightningActive = Math.random() > 0.7;
        this.lightningTimer = this.lightningActive ? 5 : 60 + Math.random() * 120;
      } else {
        this.lightningActive = false;
      }
    }
    
    // Aggiorna particelle
    for (var i = 0; i < this.particles.length; i++) {
      var p = this.particles[i];
      p.x += p.vx;
      p.y += p.vy;
      
      // Reset se fuori schermo
      if (p.y > CANVAS_H) {
        p.y = -10;
        p.x = Math.random() * CANVAS_W;
      }
      if (p.x < -10) {
        p.x = CANVAS_W + 10;
      }
    }
  },
  
  /**
   * Disegna il meteo
   */
  draw: function(ctx) {
    if (!this.active) return;
    
    // Effetto fulmine
    if (this.lightningActive) {
      ctx.fillStyle = 'rgba(255,255,255,0.3)';
      ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);
    }
    
    // Disegna particelle
    ctx.save();
    for (var i = 0; i < this.particles.length; i++) {
      var p = this.particles[i];
      ctx.globalAlpha = p.alpha;
      
      if (this.type === 'rain' || this.type === 'storm') {
        // Goccia di pioggia
        ctx.fillStyle = '#AABBCC';
        ctx.fillRect(p.x, p.y, 1, p.vy * 1.5);
      } else if (this.type === 'snow') {
        // Fiocco di neve
        ctx.fillStyle = '#FFFFFF';
        ctx.fillRect(p.x, p.y, p.size, p.size);
      }
    }
    ctx.restore();
  }
};

/**
 * Falling Leaves System
 * Foglie che cadono nei giardini
 */
var FallingLeaves = {
  active: false,
  leaves: [],
  maxLeaves: 20,
  
  /**
   * Attiva il sistema foglie
   */
  enable: function() {
    this.active = true;
    for (var i = 0; i < this.maxLeaves; i++) {
      this.leaves.push(this.createLeaf());
    }
  },
  
  /**
   * Crea una foglia
   */
  createLeaf: function() {
    var colors = ['#8B4513', '#D2691E', '#CD853F', '#DEB887', '#228B22'];
    return {
      x: Math.random() * CANVAS_W,
      y: Math.random() * CANVAS_H,
      vx: (Math.random() - 0.5) * 1.5,
      vy: 0.5 + Math.random() * 1,
      rotation: Math.random() * Math.PI * 2,
      rotSpeed: (Math.random() - 0.5) * 0.1,
      size: 3 + Math.random() * 3,
      color: colors[Math.floor(Math.random() * colors.length)],
      sway: Math.random() * Math.PI * 2
    };
  },
  
  /**
   * Aggiorna le foglie
   */
  update: function() {
    if (!this.active) return;
    
    for (var i = 0; i < this.leaves.length; i++) {
      var l = this.leaves[i];
      l.sway += 0.05;
      l.x += l.vx + Math.sin(l.sway) * 0.5;
      l.y += l.vy;
      l.rotation += l.rotSpeed;
      
      // Reset
      if (l.y > CANVAS_H + 10) {
        l.y = -10;
        l.x = Math.random() * CANVAS_W;
      }
      if (l.x < -10) l.x = CANVAS_W + 10;
      if (l.x > CANVAS_W + 10) l.x = -10;
    }
  },
  
  /**
   * Disegna le foglie
   */
  draw: function(ctx) {
    if (!this.active) return;
    
    ctx.save();
    for (var i = 0; i < this.leaves.length; i++) {
      var l = this.leaves[i];
      ctx.save();
      ctx.translate(l.x, l.y);
      ctx.rotate(l.rotation);
      ctx.fillStyle = l.color;
      ctx.fillRect(-l.size/2, -l.size/2, l.size, l.size/2);
      ctx.restore();
    }
    ctx.restore();
  }
};

/**
 * Dynamic Shadows
 * Ombre proiettate dinamicamente
 */
var ShadowSystem = {
  /**
   * Disegna ombre per un oggetto
   */
  drawShadow: function(ctx, x, y, width, height, lightX, lightY) {
    var dx = x - lightX;
    var dy = y - lightY;
    var dist = Math.sqrt(dx * dx + dy * dy);
    var shadowLen = Math.min(20, dist * 0.1);
    var angle = Math.atan2(dy, dx);
    
    ctx.save();
    ctx.fillStyle = 'rgba(0,0,0,0.2)';
    ctx.translate(x + width/2, y + height);
    ctx.rotate(angle);
    ctx.fillRect(-width/2, 0, width, shadowLen);
    ctx.restore();
  },
  
  /**
   * Disegna ombre per il player
   */
  drawPlayerShadow: function(ctx, playerX, playerY, lightSources) {
    if (!lightSources || lightSources.length === 0) return;
    
    // Usa la luce più vicina
    var nearest = lightSources[0];
    var minDist = 99999;
    
    for (var i = 0; i < lightSources.length; i++) {
      var dx = playerX - lightSources[i].x;
      var dy = playerY - lightSources[i].y;
      var dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < minDist) {
        minDist = dist;
        nearest = lightSources[i];
      }
    }
    
    this.drawShadow(ctx, playerX - 8, playerY - 4, 16, 8, nearest.x, nearest.y);
  }
};

/**
 * Torch System
 * Torcia del detective
 */
var TorchSystem = {
  active: false,
  x: 0,
  y: 0,
  angle: 0,
  radius: 60,
  
  /**
   * Attiva/disattiva la torcia
   */
  toggle: function() {
    this.active = !this.active;
  },
  
  /**
   * Aggiorna posizione torcia
   */
  update: function(playerX, playerY, facing) {
    if (!this.active) return;
    
    this.x = playerX;
    this.y = playerY - 10;
    
    // Angolo basato sulla direzione
    switch(facing) {
      case 'up': this.angle = -Math.PI/2; break;
      case 'down': this.angle = Math.PI/2; break;
      case 'left': this.angle = Math.PI; break;
      case 'right': this.angle = 0; break;
    }
  },
  
  /**
   * Disegna la luce della torcia
   */
  draw: function(ctx) {
    if (!this.active) return;
    
    ctx.save();
    ctx.globalCompositeOperation = 'screen';
    
    // Cono di luce
    ctx.translate(this.x, this.y);
    ctx.rotate(this.angle);
    
    var gradient = ctx.createRadialGradient(0, 0, 5, 0, 0, this.radius);
    gradient.addColorStop(0, 'rgba(255,240,200,0.4)');
    gradient.addColorStop(0.5, 'rgba(255,220,150,0.2)');
    gradient.addColorStop(1, 'rgba(255,200,100,0)');
    
    ctx.fillStyle = gradient;
    ctx.beginPath();
    ctx.moveTo(0, 0);
    ctx.arc(0, 0, this.radius, -Math.PI/4, Math.PI/4);
    ctx.closePath();
    ctx.fill();
    
    ctx.restore();
  }
};

/**
 * Ambient Sounds Manager
 * Gestisce suoni ambientali
 */
var AmbientAudio = {
  sounds: {},
  currentAmbience: null,
  
  /**
   * Inizializza i suoni
   */
  init: function() {
    // Placeholder per suoni - verranno caricati dinamicamente
    this.sounds = {
      'rain': { volume: 0.3, loop: true },
      'wind': { volume: 0.2, loop: true },
      'crickets': { volume: 0.15, loop: true },
      'factory': { volume: 0.25, loop: true }
    };
  },
  
  /**
   * Imposta ambiente sonoro per area
   */
  setAreaAmbience: function(areaId) {
    // Mappa aree a suoni
    var ambienceMap = {
      'piazze': 'crickets',
      'cimitero': 'wind',
      'giardini': 'crickets',
      'industriale': 'factory',
      'bar_exterior': 'crickets',
      'residenziale': 'crickets'
    };
    
    var newAmbience = ambienceMap[areaId] || 'crickets';
    if (newAmbience !== this.currentAmbience) {
      this.currentAmbience = newAmbience;
      // Qui si attiverebbe il suono reale
      console.log('Ambience:', newAmbience);
    }
  }
};

/**
 * Door Animation System
 * Porte che si aprono e chiudono
 */
var DoorSystem = {
  doors: [],
  
  init: function() {
    this.doors = [];
  },
  
  addDoor: function(x, y, w, h, type) {
    this.doors.push({
      x: x, y: y, w: w, h: h,
      type: type || 'wood',
      state: 'closed',
      openProgress: 0,
      isLocked: false
    });
  },
  
  update: function(dt) {
    for (var i = 0; i < this.doors.length; i++) {
      var door = this.doors[i];
      if (door.state === 'opening') {
        door.openProgress += dt * 2;
        if (door.openProgress >= 1) {
          door.openProgress = 1;
          door.state = 'open';
        }
      } else if (door.state === 'closing') {
        door.openProgress -= dt * 2;
        if (door.openProgress <= 0) {
          door.openProgress = 0;
          door.state = 'closed';
        }
      }
    }
  },
  
  draw: function(ctx) {
    for (var i = 0; i < this.doors.length; i++) {
      var door = this.doors[i];
      var openAmount = door.openProgress;
      
      ctx.save();
      ctx.translate(door.x + door.w/2, door.y + door.h/2);
      
      if (door.type === 'wood') {
        ctx.fillStyle = '#4a3728';
      } else if (door.type === 'metal') {
        ctx.fillStyle = '#3a3a3a';
      } else {
        ctx.fillStyle = '#5a4a3a';
      }
      
      var width = door.w * (1 - openAmount * 0.7);
      var skew = openAmount * 20;
      
      ctx.beginPath();
      ctx.moveTo(-width/2, -door.h/2);
      ctx.lineTo(width/2, -door.h/2 + skew);
      ctx.lineTo(width/2, door.h/2 + skew);
      ctx.lineTo(-width/2, door.h/2);
      ctx.closePath();
      ctx.fill();
      
      // Maniglia
      ctx.fillStyle = '#d4af37';
      ctx.fillRect(width/2 - 8, -5, 6, 10);
      
      ctx.restore();
    }
  },
  
  interact: function(px, py) {
    for (var i = 0; i < this.doors.length; i++) {
      var door = this.doors[i];
      if (px > door.x - 20 && px < door.x + door.w + 20 &&
          py > door.y - 20 && py < door.y + door.h + 20) {
        if (door.state === 'closed') door.state = 'opening';
        else if (door.state === 'open') door.state = 'closing';
        return true;
      }
    }
    return false;
  }
};

/**
 * Window Light System
 * Luci nelle finestre che si accendono/spegono
 */
var WindowSystem = {
  windows: [],
  
  init: function() {
    this.windows = [];
  },
  
  addWindow: function(x, y, w, h) {
    this.windows.push({
      x: x, y: y, w: w, h: h,
      lit: Math.random() > 0.5,
      flickerTimer: 0,
      color: Math.random() > 0.7 ? '#fff8e1' : '#ffe4b5'
    });
  },
  
  update: function(dt) {
    for (var i = 0; i < this.windows.length; i++) {
      var win = this.windows[i];
      if (win.lit) {
        win.flickerTimer += dt;
        // Occasionale flicker
        if (Math.random() < 0.01) {
          win.flickerTimer = Math.random() * 0.1;
        }
      }
    }
  },
  
  draw: function(ctx) {
    for (var i = 0; i < this.windows.length; i++) {
      var win = this.windows[i];
      if (!win.lit) continue;
      
      var flicker = Math.sin(win.flickerTimer * 20) * 0.1 + 0.9;
      
      ctx.save();
      ctx.globalCompositeOperation = 'screen';
      ctx.globalAlpha = 0.6 * flicker;
      
      var gradient = ctx.createRadialGradient(
        win.x + win.w/2, win.y + win.h/2, 0,
        win.x + win.w/2, win.y + win.h/2, win.w
      );
      gradient.addColorStop(0, win.color);
      gradient.addColorStop(1, 'transparent');
      
      ctx.fillStyle = gradient;
      ctx.fillRect(win.x - 5, win.y - 5, win.w + 10, win.h + 10);
      
      ctx.globalAlpha = 0.9 * flicker;
      ctx.fillStyle = win.color;
      ctx.fillRect(win.x, win.y, win.w, win.h);
      
      ctx.restore();
    }
  },
  
  setWindowLit: function(index, lit) {
    if (this.windows[index]) {
      this.windows[index].lit = lit;
    }
  }
};

/**
 * Wildlife Animation System
 * Animali ambientali (uccelli, insetti, gatti)
 */
var WildlifeSystem = {
  creatures: [],
  
  init: function() {
    this.creatures = [];
  },
  
  addBird: function(x, y) {
    this.creatures.push({
      type: 'bird',
      x: x, y: y,
      vx: (Math.random() - 0.5) * 2,
      vy: -Math.random() * 2 - 1,
      wingPhase: 0,
      life: 300
    });
  },
  
  addButterfly: function(x, y) {
    this.creatures.push({
      type: 'butterfly',
      x: x, y: y,
      vx: (Math.random() - 0.5) * 0.5,
      vy: (Math.random() - 0.5) * 0.5,
      wingPhase: Math.random() * Math.PI * 2,
      color: ['#ff6b6b', '#4ecdc4', '#ffe66d'][Math.floor(Math.random() * 3)],
      life: 600
    });
  },
  
  addCat: function(x, y) {
    this.creatures.push({
      type: 'cat',
      x: x, y: y,
      vx: 0, vy: 0,
      state: 'idle',
      timer: 0,
      facing: 1
    });
  },
  
  update: function(dt) {
    for (var i = this.creatures.length - 1; i >= 0; i--) {
      var c = this.creatures[i];
      c.life -= dt * 60;
      
      if (c.type === 'bird') {
        c.x += c.vx;
        c.y += c.vy;
        c.wingPhase += dt * 15;
        if (c.life <= 0 || c.y < -50) {
          this.creatures.splice(i, 1);
        }
      } else if (c.type === 'butterfly') {
        c.x += c.vx + Math.sin(c.wingPhase) * 0.3;
        c.y += c.vy + Math.cos(c.wingPhase * 0.7) * 0.2;
        c.wingPhase += dt * 8;
        if (c.life <= 0) {
          this.creatures.splice(i, 1);
        }
      } else if (c.type === 'cat') {
        c.timer += dt;
        if (c.state === 'idle' && c.timer > 2) {
          c.state = 'walking';
          c.vx = (Math.random() - 0.5) * 1;
          c.timer = 0;
        } else if (c.state === 'walking') {
          c.x += c.vx;
          if (c.vx > 0) c.facing = 1;
          else if (c.vx < 0) c.facing = -1;
          if (c.timer > 3 || c.x < 50 || c.x > CANVAS_W - 50) {
            c.state = 'idle';
            c.vx = 0;
            c.timer = 0;
          }
        }
      }
    }
  },
  
  draw: function(ctx) {
    for (var i = 0; i < this.creatures.length; i++) {
      var c = this.creatures[i];
      ctx.save();
      ctx.translate(c.x, c.y);
      
      if (c.type === 'bird') {
        var wingY = Math.sin(c.wingPhase) * 5;
        ctx.fillStyle = '#333';
        ctx.beginPath();
        ctx.moveTo(-6, -wingY);
        ctx.lineTo(0, 2);
        ctx.lineTo(6, -wingY);
        ctx.fill();
      } else if (c.type === 'butterfly') {
        var wingScale = Math.abs(Math.sin(c.wingPhase));
        ctx.fillStyle = c.color;
        ctx.save();
        ctx.scale(wingScale, 1);
        ctx.beginPath();
        ctx.ellipse(-3, 0, 4, 3, 0, 0, Math.PI * 2);
        ctx.ellipse(3, 0, 4, 3, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      } else if (c.type === 'cat') {
        ctx.scale(c.facing, 1);
        ctx.fillStyle = '#d4a574';
        ctx.fillRect(-8, -6, 16, 10);
        ctx.fillRect(-10, -8, 4, 6);
        ctx.fillRect(6, -8, 4, 6);
        ctx.fillStyle = '#333';
        ctx.fillRect(4, -4, 2, 2);
      }
      
      ctx.restore();
    }
  }
};

/**
 * UI Transition System
 * Transizioni tra schermate
 */
var UITransitions = {
  active: false,
  type: 'fade',
  progress: 0,
  duration: 0.5,
  callback: null,
  
  start: function(type, duration, callback) {
    this.active = true;
    this.type = type || 'fade';
    this.progress = 0;
    this.duration = duration || 0.5;
    this.callback = callback;
  },
  
  update: function(dt) {
    if (!this.active) return;
    
    this.progress += dt / this.duration;
    if (this.progress >= 1) {
      this.progress = 1;
      this.active = false;
      if (this.callback) this.callback();
    }
  },
  
  draw: function(ctx) {
    if (!this.active && this.progress <= 0) return;
    
    ctx.save();
    var alpha = this.type === 'fade' ? this.progress : 0;
    
    if (this.type === 'wipe') {
      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, CANVAS_W * this.progress, CANVAS_H);
    } else if (this.type === 'circle') {
      ctx.fillStyle = '#000';
      ctx.beginPath();
      var radius = Math.max(CANVAS_W, CANVAS_H) * this.progress;
      ctx.arc(CANVAS_W/2, CANVAS_H/2, radius, 0, Math.PI * 2);
      ctx.fill();
    } else {
      ctx.fillStyle = 'rgba(0,0,0,' + alpha + ')';
      ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);
    }
    ctx.restore();
  }
};

/**
 * Menu Animation System
 * Animazioni per menu e UI
 */
var MenuAnimations = {
  buttons: [],
  selectedIndex: -1,
  
  init: function() {
    this.buttons = [];
    this.selectedIndex = -1;
  },
  
  addButton: function(x, y, w, h, text) {
    this.buttons.push({
      x: x, y: y, w: w, h: h,
      text: text,
      hover: false,
      scale: 1,
      glow: 0
    });
  },
  
  update: function(dt, mouseX, mouseY) {
    for (var i = 0; i < this.buttons.length; i++) {
      var btn = this.buttons[i];
      var wasHover = btn.hover;
      btn.hover = mouseX > btn.x && mouseX < btn.x + btn.w &&
                  mouseY > btn.y && mouseY < btn.y + btn.h;
      
      if (btn.hover) {
        btn.scale += (1.05 - btn.scale) * dt * 10;
        btn.glow += (1 - btn.glow) * dt * 5;
        if (!wasHover) this.selectedIndex = i;
      } else {
        btn.scale += (1 - btn.scale) * dt * 10;
        btn.glow += (0 - btn.glow) * dt * 5;
      }
    }
  },
  
  draw: function(ctx) {
    for (var i = 0; i < this.buttons.length; i++) {
      var btn = this.buttons[i];
      ctx.save();
      ctx.translate(btn.x + btn.w/2, btn.y + btn.h/2);
      ctx.scale(btn.scale, btn.scale);
      
      if (btn.glow > 0) {
        ctx.shadowColor = PALETTE.accent;
        ctx.shadowBlur = btn.glow * 15;
      }
      
      ctx.fillStyle = btn.hover ? PALETTE.accent : PALETTE.uiBg;
      ctx.fillRect(-btn.w/2, -btn.h/2, btn.w, btn.h);
      
      ctx.fillStyle = btn.hover ? '#000' : PALETTE.textLight;
      ctx.font = '12px "Press Start 2P"';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(btn.text, 0, 0);
      
      ctx.restore();
    }
  },
  
  click: function(mouseX, mouseY) {
    for (var i = 0; i < this.buttons.length; i++) {
      var btn = this.buttons[i];
      if (mouseX > btn.x && mouseX < btn.x + btn.w &&
          mouseY > btn.y && mouseY < btn.y + btn.h) {
        return i;
      }
    }
    return -1;
  }
};

/**
 * Puzzle Animation System
 * Animazioni per puzzle e oggetti interattivi
 */
var PuzzleAnimations = {
  pieces: [],
  
  init: function() {
    this.pieces = [];
  },
  
  addPiece: function(x, y, w, h, type) {
    this.pieces.push({
      x: x, y: y, w: w, h: h,
      type: type,
      selected: false,
      solved: false,
      floatOffset: Math.random() * Math.PI * 2,
      rotation: 0,
      scale: 1
    });
  },
  
  update: function(dt) {
    for (var i = 0; i < this.pieces.length; i++) {
      var piece = this.pieces[i];
      piece.floatOffset += dt * 2;
      
      if (piece.selected) {
        piece.scale += (1.1 - piece.scale) * dt * 8;
      } else if (piece.solved) {
        piece.scale += (1.05 - piece.scale) * dt * 4;
      } else {
        piece.scale += (1 - piece.scale) * dt * 8;
      }
    }
  },
  
  draw: function(ctx) {
    for (var i = 0; i < this.pieces.length; i++) {
      var piece = this.pieces[i];
      var floatY = Math.sin(piece.floatOffset) * 3;
      
      ctx.save();
      ctx.translate(piece.x + piece.w/2, piece.y + piece.h/2 + floatY);
      ctx.scale(piece.scale, piece.scale);
      
      if (piece.selected) {
        ctx.shadowColor = PALETTE.accent;
        ctx.shadowBlur = 15;
      } else if (piece.solved) {
        ctx.shadowColor = '#0f0';
        ctx.shadowBlur = 10;
      }
      
      if (piece.type === 'gear') {
        ctx.fillStyle = piece.solved ? '#6a5' : '#8a7';
        ctx.beginPath();
        ctx.arc(0, 0, piece.w/3, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = '#443';
        ctx.beginPath();
        ctx.arc(0, 0, piece.w/6, 0, Math.PI * 2);
        ctx.fill();
      } else if (piece.type === 'switch') {
        ctx.fillStyle = '#555';
        ctx.fillRect(-piece.w/2, -piece.h/2, piece.w, piece.h);
        ctx.fillStyle = piece.solved ? '#0f0' : '#f00';
        ctx.fillRect(-piece.w/4, -piece.h/4, piece.w/2, piece.h/2);
      } else {
        ctx.fillStyle = piece.solved ? PALETTE.accent : PALETTE.uiBg;
        ctx.fillRect(-piece.w/2, -piece.h/2, piece.w, piece.h);
      }
      
      ctx.restore();
    }
  },
  
  select: function(index) {
    for (var i = 0; i < this.pieces.length; i++) {
      this.pieces[i].selected = (i === index);
    }
  },
  
  markSolved: function(index) {
    if (this.pieces[index]) {
      this.pieces[index].solved = true;
      this.pieces[index].selected = false;
    }
  }
};

/**
 * Interactive Objects System
 * Oggetti interattivi animati
 */
var InteractiveObjects = {
  objects: [],
  
  init: function() {
    this.objects = [];
  },
  
  addObject: function(x, y, type, data) {
    this.objects.push({
      x: x, y: y,
      type: type,
      data: data || {},
      animPhase: 0,
      interacted: false,
      highlight: 0
    });
  },
  
  update: function(dt, px, py) {
    for (var i = 0; i < this.objects.length; i++) {
      var obj = this.objects[i];
      obj.animPhase += dt * 3;
      
      var dx = px - obj.x;
      var dy = py - obj.y;
      var dist = Math.sqrt(dx*dx + dy*dy);
      
      if (dist < 40) {
        obj.highlight += (1 - obj.highlight) * dt * 5;
      } else {
        obj.highlight += (0 - obj.highlight) * dt * 5;
      }
    }
  },
  
  draw: function(ctx) {
    for (var i = 0; i < this.objects.length; i++) {
      var obj = this.objects[i];
      ctx.save();
      ctx.translate(obj.x, obj.y);
      
      if (obj.highlight > 0) {
        ctx.shadowColor = PALETTE.accent;
        ctx.shadowBlur = obj.highlight * 20;
      }
      
      if (obj.type === 'chest') {
        var bounce = obj.interacted ? 0 : Math.sin(obj.animPhase) * 2;
        ctx.fillStyle = '#8b6914';
        ctx.fillRect(-12, -10 + bounce, 24, 20);
        ctx.fillStyle = '#d4af37';
        ctx.fillRect(-3, -2 + bounce, 6, 4);
      } else if (obj.type === 'crystal') {
        var pulse = 0.8 + Math.sin(obj.animPhase * 2) * 0.2;
        ctx.fillStyle = '#9cf';
        ctx.globalAlpha = pulse;
        ctx.beginPath();
        ctx.moveTo(0, -12);
        ctx.lineTo(6, -2);
        ctx.lineTo(0, 10);
        ctx.lineTo(-6, -2);
        ctx.closePath();
        ctx.fill();
        ctx.globalAlpha = 1;
      } else if (obj.type === 'sign') {
        ctx.fillStyle = '#5a4a3a';
        ctx.fillRect(-10, -15, 20, 12);
        ctx.fillStyle = '#3a3020';
        ctx.fillRect(-2, -3, 4, 15);
      }
      
      ctx.restore();
    }
  },
  
  interact: function(px, py) {
    for (var i = 0; i < this.objects.length; i++) {
      var obj = this.objects[i];
      var dx = px - obj.x;
      var dy = py - obj.y;
      if (Math.sqrt(dx*dx + dy*dy) < 30) {
        obj.interacted = true;
        return { index: i, type: obj.type, data: obj.data };
      }
    }
    return null;
  }
};
